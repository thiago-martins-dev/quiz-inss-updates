{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "sourceRepository", "sourceCommit", "productionQuestionCount", "uniqueIdCount", "duplicateIdCount", "dependencies", "unresolved", "statistics"],
  "properties": {
    "schemaVersion": {"const": 1},
    "generatedAt": {"type": "string"},
    "sourceRepository": {"type": "string"},
    "sourceCommit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "productionQuestionCount": {"const": 707},
    "uniqueIdCount": {"const": 707},
    "duplicateIdCount": {"const": 0},
    "dependencies": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["contentType", "contentId", "normId", "article", "paragraph", "item", "letter", "referenceType", "confidence", "sourceLocation", "eligibleForAutomaticAction", "historical", "activeForCurrentStudy"], "properties": {"contentType": {"const": "question"}, "contentId": {"type": "integer"}, "normId": {"type": "string"}, "article": {"type": "string"}, "paragraph": {"type": ["string", "null"]}, "item": {"type": ["string", "null"]}, "letter": {"type": ["string", "null"]}, "referenceType": {"enum": ["explicit", "extracted", "inferred"]}, "confidence": {"type": "number", "minimum": 0, "maximum": 1}, "sourceLocation": {"type": "string"}, "eligibleForAutomaticAction": {"type": "boolean"}, "historical": {"type": "boolean"}, "activeForCurrentStudy": {"type": "boolean"}}}},
    "unresolved": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["contentId", "sourceLocation", "reason", "candidateReference", "requiresReview"], "properties": {"contentId": {"type": "integer"}, "sourceLocation": {"type": "string"}, "reason": {"enum": ["missingNorm", "missingArticle", "ambiguousNorm", "ambiguousArticle", "unsupportedFormat", "nonLegalSubject", "noLegalReference"]}, "candidateReference": {"type": ["string", "null"]}, "requiresReview": {"const": true}}}},
    "statistics": {"type": "object", "additionalProperties": false, "required": ["explicit", "extracted", "inferred", "eligible", "historical", "unresolved"], "properties": {"explicit": {"type": "integer"}, "extracted": {"type": "integer"}, "inferred": {"type": "integer"}, "eligible": {"type": "integer"}, "historical": {"type": "integer"}, "unresolved": {"type": "integer"}}}
  }
}
