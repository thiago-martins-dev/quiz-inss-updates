{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/thiago-martins-dev/quiz-inss-updates/main/schemas/content-package.schema.json",
  "title": "Quiz INSS Safe Legal Content Package",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "packageId", "packageType", "packageVersion", "contentVersionFrom", "contentVersionTo", "createdAt", "minimumAppVersion", "sourceMonitorCommit", "sources", "operations", "integrity"],
  "properties": {
    "schemaVersion": {"const": 1},
    "packageId": {"type": "string", "pattern": "^legal-[a-f0-9]{32}$"},
    "packageType": {"const": "legal-content"},
    "packageVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "contentVersionFrom": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "contentVersionTo": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "createdAt": {"type": "string"},
    "minimumAppVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "sourceMonitorCommit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "sources": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["normId", "officialUrl", "collectedAt", "documentSha256", "affectedDevices"], "properties": {"normId": {"type": "string"}, "officialUrl": {"type": "string", "pattern": "^https://"}, "collectedAt": {"type": "string"}, "documentSha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "affectedDevices": {"type": "array", "items": {"type": "string"}}}}},
    "operations": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["operationId", "action", "entity", "id", "expectedCurrentState", "payload", "preserveHistory", "idempotencyKey", "legalBasis", "detectedAt", "effectiveAt"], "properties": {"operationId": {"type": "string", "pattern": "^op-[a-f0-9]{24}$"}, "action": {"enum": ["update", "deactivate"]}, "entity": {"enum": ["question", "legislation", "summaryMetadata"]}, "id": {"type": ["string", "integer"]}, "expectedCurrentState": {"type": "object"}, "payload": {"type": "object"}, "preserveHistory": {"const": true}, "idempotencyKey": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "legalBasis": {"type": "object"}, "detectedAt": {"type": "string"}, "effectiveAt": {"type": ["string", "null"]}}}},
    "integrity": {"type": "object", "additionalProperties": false, "required": ["algorithm", "operationsSha256"], "properties": {"algorithm": {"const": "SHA-256"}, "operationsSha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}}
  }
}
